<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.AppTheme" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/neon_cyan</item>
        <item name="colorPrimaryVariant">@color/neon_purple</item>
        <item name="colorOnPrimary">@color/dark_bg</item>
        <item name="colorSecondary">@color/neon_pink</item>
        <item name="colorSecondaryVariant">@color/neon_magenta</item>
        <item name="colorOnSecondary">@color/dark_bg</item>
        <item name="android:colorBackground">@color/dark_bg</item>
        <item name="colorSurface">@color/dark_surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:statusBarColor">@color/dark_bg</item>
        <item name="android:navigationBarColor">@color/dark_bg</item>
    </style>

    <style name="AppTheme" parent="Base.AppTheme" />

    <style name="TaskFlowDialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="android:background">@color/dark_surface</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="buttonBarPositiveButtonStyle">@style/TaskFlowDialogButton</item>
        <item name="buttonBarNegativeButtonStyle">@style/TaskFlowDialogButtonCancel</item>
    </style>

    <style name="TaskFlowDialogButton" parent="Widget.Material3.Button.TextButton.Dialog">
        <item name="android:textColor">@color/neon_cyan</item>
    </style>

    <style name="TaskFlowDialogButtonCancel" parent="Widget.Material3.Button.TextButton.Dialog">
        <item name="android:textColor">@color/text_secondary</item>
    </style>
</resources>
